# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Chat - Server-side only (for Vercel Function)
# Configure GEMINI_API_KEY in Vercel Dashboard > Settings > Environment Variables
# This key is NEVER exposed to the browser
# GEMINI_API_KEY=your-gemini-api-key

# Blink UI (OPTIONAL - if using @blinkdotnew/ui)
# VITE_BLINK_PROJECT_ID=your-blink-project-id
# VITE_BLINK_PUBLISHABLE_KEY=your-blink-publishable-key

# reCAPTCHA (OPTIONAL)
# VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
